# Railway injects PORT automatically. Do not set PORT unless you have a specific reason.
HOST=0.0.0.0

# Recommended Railway volume mount path for this project.
# Create a Railway Volume and mount it to /app/data, then set DATA_DIR to the same path.
DATA_DIR=/app/data
STORAGE_ENGINE=json
DATABASE_URL=
ADMIN_TOKEN=

# App review / external test demo URLs. Use the public HTTPS Railway URL or your custom domain.
REVIEW_DEMO_URL=
PRIVACY_POLICY_URL=
SUPPORT_URL=
REVIEW_NOTES_URL=
STORE_SCREENSHOT_DIR=mobile/store-assets/screenshots

POLL_INTERVAL_SECONDS=60
TELEGRAM_COMMAND_POLL_SECONDS=5
DIVIDEND_REFRESH_INTERVAL_SECONDS=86400
DAILY_BRIEFING_ENABLED=true
DAILY_BRIEFING_TIME=16:10
DAILY_BRIEFING_CHECK_INTERVAL_SECONDS=60
DAILY_BRIEFING_WARNING_DISTANCE_PERCENT=5
DAILY_BRIEFING_TOP_LIMIT=5
DIVIDEND_EVENT_ALERT_ENABLED=true
DIVIDEND_EVENT_ALERT_CHECK_INTERVAL_SECONDS=3600
DIVIDEND_EVENT_ALERT_EX_DATE_OFFSETS=3,1,0,-1
DIVIDEND_EVENT_ALERT_PAYMENT_DATE_OFFSETS=1,0
BACKUP_RETENTION=30
DEFAULT_ALERT_COOLDOWN_MINUTES=30
QUOTE_TIMEOUT_MS=10000
QUOTE_PROVIDERS=naver,stooq,alphavantage,yahoo
DIVIDEND_PROVIDERS=publicdata,opendart,alphavantage,yahoo

# Optional. Used when DIVIDEND_PROVIDERS includes publicdata.
DATA_GO_KR_SERVICE_KEY=

# Optional. Used when DIVIDEND_PROVIDERS includes opendart.
OPENDART_API_KEY=

# Optional. Used when QUOTE_PROVIDERS or DIVIDEND_PROVIDERS includes alphavantage.
ALPHA_VANTAGE_API_KEY=

# Optional. Used when QUOTE_PROVIDERS includes nxt. Requires official/contract API endpoint.
NXT_QUOTE_ENDPOINT_TEMPLATE=
NXT_API_KEY=
NXT_API_KEY_HEADER=Authorization
NXT_API_KEY_SCHEME=Bearer

# Optional. Broker API adapter review. Quote-only; trading remains disabled.
BROKER_QUOTE_PROVIDER=none
BROKER_TRADING_ENABLED=false
KIS_API_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCESS_TOKEN=
KIS_ACCOUNT_NUMBER=
KIS_MARKET_DIV_CODE=J
KIS_CUST_TYPE=P
KIS_TOKEN_AUTO_REFRESH=true
KIS_TOKEN_CACHE_PATH=
KIWOOM_API_BASE_URL=https://api.kiwoom.com
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
KIWOOM_ACCESS_TOKEN=
KIWOOM_ACCOUNT_NUMBER=

# Create a Telegram bot with BotFather and put the token here.
TELEGRAM_BOT_TOKEN=

# Send a message to your bot, then use Telegram getUpdates to find the chat id.
TELEGRAM_CHAT_ID=

# Mobile push notifications use Expo Push by default.
MOBILE_PUSH_ENABLED=true
EXPO_PUSH_ENDPOINT=https://exp.host/--/api/v2/push/send
