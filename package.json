{
  "name": "stock-alarm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram-based stock drawdown alert MVP.",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "stop": "node scripts/stop-server.js",
    "local:start": "node scripts/local-server.js start",
    "local:phone": "node scripts/local-server.js start-lan",
    "local:status": "node scripts/local-server.js status",
    "check:railway": "node scripts/check-railway-config.js",
    "check:demo": "node scripts/check-demo-server.js",
    "check:store-assets": "node scripts/check-store-assets.js",
    "check:broker-api": "node scripts/check-broker-api.js",
    "check:publicdata-price": "node scripts/check-publicdata-price.js",
    "migrate:postgres:dry-run": "node scripts/json-to-postgres-dry-run.js",
    "migrate:postgres:rehearsal": "node scripts/postgres-connection-rehearsal.js",
    "mobile:install": "npm --prefix mobile install",
    "mobile:start": "npm --prefix mobile start",
    "test": "node --test"
  },
  "optionalDependencies": {
    "pg": "^8.13.1"
  },
  "engines": {
    "node": ">=20"
  }
}
